# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# REQUIRED in production — min 32 chars random string
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Database (optional — omit for in-memory storage) ───
# DATABASE_URL=postgresql://user:pass@localhost:5432/juphd

# ── Access control ────────────────────────────────────
# Restrict registration to specific email domains (comma-separated).
# Leave unset to allow any email (dev mode).
# Example: ALLOWED_EMAIL_DOMAINS=minhaempresa.com.br,contratada.com
# ALLOWED_EMAIL_DOMAINS=

# ── Chat / AI ──────────────────────────────────────────
# REQUIRED in production — /api/chat returns 503 if unset
CHAT_ORCHESTRATOR_URL=

# ── Replit (auto-set by Replit runtime — do NOT set manually)
# REPL_ID=
